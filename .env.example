# Apex host used to derive association subdomains. For local development set
# this to the dev host that resolves to 127.0.0.1 via your hosts file
# (run `bun run hosts init`). In production set it to the real apex domain.
NUXT_HOST=trailassociation.test

# Secret used to sign session cookies. Must be at least 32 characters.
NUXT_SESSION_PASSWORD=replace-with-a-random-secret-min-32-chars

# MongoDB connection string.
MONGO_CONNECTION_STRING=mongodb://localhost:27017/trailassociation?appName=trailassociationuk
